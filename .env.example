# Meridian deployment environment
NEXT_PUBLIC_APP_URL="https://meridian.your-company.com"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/meridian?schema=public"

# Auth.js / Microsoft Entra ID
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-32-plus-character-secret"
AUTH_MICROSOFT_ENTRA_ID_ID="<Application client ID>"
AUTH_MICROSOFT_ENTRA_ID_SECRET="<Client secret value>"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<Directory tenant ID>/v2.0/"
MERIDIAN_AUTH_MODE="entra"

# Optional role mapping when using Entra group claims instead of app roles.
ENTRA_ADMIN_GROUP_ID="<Admin group object ID>"
ENTRA_MANAGER_GROUP_ID="<Manager group object ID>"
ENTRA_EMPLOYEE_GROUP_ID="<Employee group object ID>"

# Microsoft Graph app-only sync for org hierarchy and reporting lines.
MICROSOFT_TENANT_ID="<Directory tenant ID>"
MICROSOFT_GRAPH_CLIENT_ID="<Graph sync application client ID>"
MICROSOFT_GRAPH_CLIENT_SECRET="<Graph sync client secret>"

# Demo-only API fallback. Never use this as production auth.
MERIDIAN_DEMO_API_KEY="replace-with-demo-only-local-key"
